  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["# 🌲 Forest Dead Tree Detection — Demo\n\nAutomatic detection of dead and diseased trees from aerial RGB satellite imagery.\n\n**Dataset**: 345 RGB images (224×224), Arkansas & Missouri counties 2018–2021  \n**Model**: U-Net with EfficientNetB0 encoder (pretrained ImageNet)  \n**Task**: Binary pixel-level segmentation (dead tree = 1, background = 0)"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "import os\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.gridspec as gridspec\n",
    "from pathlib import Path\n",
    "from PIL import Image\n",
    "\n",
    "# Dark matplotlib theme\n",
    "plt.style.use('dark_background')\n",
    "\n",
    "# Paths\n",
    "PROJECT_ROOT = Path('..').resolve()\n",
    "DATA_ROOT    = PROJECT_ROOT.parent / 'USA_segmentation'\n",
    "IMG_DIR      = DATA_ROOT / 'RGB_images'\n",
    "MASK_DIR     = DATA_ROOT / 'masks'\n",
    "MODEL_KERAS  = PROJECT_ROOT / 'outputs' / 'best_unet_model.keras'\n",
    "MODEL_H5     = DATA_ROOT / 'best_unet_model.h5'\n",
    "\n",
    "sys.path.insert(0, str(PROJECT_ROOT / 'src'))\n",
    "print('Project root:', PROJECT_ROOT)\n",
    "print('Data root:   ', DATA_ROOT)\n",
    "print('Images found:', len(list(IMG_DIR.glob('*.png'))) if IMG_DIR.exists() else 'DIR NOT FOUND')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 1. Load and Visualize 5 Sample Images"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "samples = sorted(IMG_DIR.glob('*.png'))[:5]\n",
    "fig, axes = plt.subplots(2, 5, figsize=(18, 8))\n",
    "fig.suptitle('Sample Images & Masks', fontsize=16, color='white')\n",
    "\n",
    "for i, img_path in enumerate(samples):\n",
    "    mask_name = img_path.name.replace('RGB_', 'mask_')\n",
    "    mask_path = MASK_DIR / mask_name\n",
    "\n",
    "    img  = Image.open(img_path).convert('RGB').resize((224, 224))\n",
    "    mask = Image.open(mask_path).convert('L').resize((224, 224)) if mask_path.exists() else Image.new('L', (224,224))\n",
    "\n",
    "    axes[0, i].imshow(np.array(img))\n",
    "    axes[0, i].set_title(img_path.stem[:20], fontsize=8, color='white')\n",
    "    axes[0, i].axis('off')\n",
    "\n",
    "    axes[1, i].imshow(np.array(mask), cmap='Reds')\n",
    "    axes[1, i].set_title('Mask', fontsize=8, color='white')\n",
    "    axes[1, i].axis('off')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 2. Augmentation Before / After"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from dataset import build_augmentation, augment_image_mask\n",
    "\n",
    "aug = build_augmentation('train')\n",
    "\n",
    "img_path  = samples[0]\n",
    "mask_name = img_path.name.replace('RGB_', 'mask_')\n",
    "mask_path = MASK_DIR / mask_name\n",
    "\n",
    "img_arr  = np.array(Image.open(img_path).convert('RGB').resize((224,224)), dtype=np.float32) / 255.0\n",
    "mask_arr = np.array(Image.open(mask_path).convert('L').resize((224,224)), dtype=np.float32) / 255.0\n",
    "mask_arr = np.round(mask_arr)[..., np.newaxis]\n",
    "\n",
    "fig, axes = plt.subplots(2, 4, figsize=(16, 8))\n",
    "fig.suptitle('Augmentation Examples', fontsize=14)\n",
    "\n",
    "for col in range(4):\n",
    "    if col == 0:\n",
    "        aug_img, aug_mask = img_arr, mask_arr\n",
    "        title = 'Original'\n",
    "    else:\n",
    "        aug_img, aug_mask = augment_image_mask(img_arr, mask_arr, aug)\n",
    "        title = f'Augmented #{col}'\n",
    "\n",
    "    axes[0, col].imshow(aug_img)\n",
    "    axes[0, col].set_title(title, color='white')\n",
    "    axes[0, col].axis('off')\n",
    "\n",
    "    axes[1, col].imshow(aug_mask.squeeze(), cmap='Reds')\n",
    "    axes[1, col].set_title('Mask', color='white')\n",
    "    axes[1, col].axis('off')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 3. Load Best Model"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import tensorflow as tf\n",
    "import tensorflow.keras.backend as K\n",
    "\n",
    "def dice_coefficient(y_true, y_pred, smooth=1.):\n",
    "    y_true_f, y_pred_f = K.flatten(y_true), K.flatten(y_pred)\n",
    "    return (2.*K.sum(y_true_f*y_pred_f)+smooth) / (K.sum(y_true_f)+K.sum(y_pred_f)+smooth)\n",
    "\n",
    "def dice_loss(y_true, y_pred): return 1.0 - dice_coefficient(y_true, y_pred)\n",
    "\n",
    "def combined_loss(y_true, y_pred):\n",
    "    return 0.5*dice_loss(y_true,y_pred) + 0.5*tf.keras.losses.binary_crossentropy(y_true,y_pred)\n",
    "\n",
    "custom_objects = {'dice_coefficient': dice_coefficient, 'dice_loss': dice_loss, 'combined_loss': combined_loss}\n",
    "\n",
    "model_path = MODEL_KERAS if MODEL_KERAS.exists() else MODEL_H5\n",
    "print(f'Loading model from: {model_path}')\n",
    "\n",
    "model = tf.keras.models.load_model(str(model_path), custom_objects=custom_objects)\n",
    "print('✅ Model loaded successfully!')\n",
    "print(f'Input shape:  {model.input_shape}')\n",
    "print(f'Output shape: {model.output_shape}')\n",
    "print(f'Parameters:   {model.count_params():,}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 4. Predict on Test Samples"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "THRESHOLD = 0.5\n",
    "test_samples = samples[:3]\n",
    "\n",
    "fig, axes = plt.subplots(3, 3, figsize=(14, 14))\n",
    "fig.suptitle(f'Predictions (threshold={THRESHOLD})', fontsize=14)\n",
    "col_titles = ['Original Image', 'Ground Truth', 'U-Net Prediction']\n",
    "for ax, t in zip(axes[0], col_titles):\n",
    "    ax.set_title(t, fontsize=11, color='white')\n",
    "\n",
    "for row, img_path in enumerate(test_samples):\n",
    "    mask_name = img_path.name.replace('RGB_', 'mask_')\n",
    "    mask_path = MASK_DIR / mask_name\n",
    "\n",
    "    img_arr  = np.array(Image.open(img_path).convert('RGB').resize((224,224)), dtype=np.float32)/255.0\n",
    "    mask_arr = np.array(Image.open(mask_path).convert('L').resize((224,224)), dtype=np.float32)/255.0 if mask_path.exists() else np.zeros((224,224))\n",
    "\n",
    "    x = img_arr[np.newaxis]\n",
    "    prob = model.predict(x, verbose=0)[0, :, :, 0]\n",
    "    pred = (prob >= THRESHOLD).astype(np.uint8)\n",
    "\n",
    "    axes[row, 0].imshow(img_arr)\n",
    "    axes[row, 1].imshow(mask_arr, cmap='Reds', vmin=0, vmax=1)\n",
    "    axes[row, 2].imshow(pred,     cmap='Reds', vmin=0, vmax=1)\n",
    "    for ax in axes[row]: ax.axis('off')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 5. Compute Metrics on Test Set"]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from dataset import load_dataset, split_dataset\n",
    "from metrics import compute_all_metrics\n",
    "\n",
    "print('Loading dataset…')\n",
    "X, Y, filenames = load_dataset(str(IMG_DIR), str(MASK_DIR), verbose=True)\n",
    "splits = split_dataset(X, Y)\n",
    "X_test, Y_test = splits['X_test'], splits['Y_test']\n",
    "print(f'Test set: {len(X_test)} images')\n",
    "\n",
    "all_metrics = []\n",
    "for i, (img, mask) in enumerate(zip(X_test, Y_test)):\n",
    "    prob = model.predict(img[np.newaxis], verbose=0)[0,:,:,0]\n",
    "    m = compute_all_metrics(mask.squeeze(), prob, threshold=0.5)\n",
    "    all_metrics.append(m)\n",
    "\n",
    "import pandas as pd\n",
    "df = pd.DataFrame(all_metrics)\n",
    "print('\\n📊 Test Set Metrics:')\n",
    "print(df.mean().round(4).to_string())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": ["## 6. Count Dead Trees (Connected Components)"]
