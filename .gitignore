# ── Model weights (large binary files) ───────────────────────────────────────
*.h5
*.keras
*.pkl
*.pt
*.pth

# ── Generated outputs ─────────────────────────────────────────────────────────
outputs/
!outputs/.gitkeep

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pycache

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Build / dist ──────────────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Jupyter checkpoints ───────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Logs & temp ───────────────────────────────────────────────────────────────
*.log
*.tmp
wandb/
mlruns/
logs/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Test cache ────────────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
